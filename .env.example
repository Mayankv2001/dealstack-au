# DealStack AU — environment variables
# Copy to .env.local (which is gitignored) and fill in real values.
# Never commit real keys. The service-role key is server/script only.

# Public Supabase config (safe to expose to the browser; RLS-limited)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server/script ONLY — bypasses RLS. Do NOT prefix with NEXT_PUBLIC_.
# Used by scripts/seed.ts now, and admin server actions later.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional (used in later phases)
# Admin allowlist for Supabase Auth (comma-separated)
# ADMIN_EMAILS=you@example.com
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Force the static fallback even if Supabase is configured: static | supabase
# DATA_SOURCE=supabase

# OzBargain feed monitor (FUTURE / NOT IMPLEMENTED) — leave unset/off.
# Gated on the compliance review in docs/ozbargain-monitoring.md. The monitor
# only runs when OZB_MONITOR_ENABLED=true AND a feed_sources row is enabled.
# OZB_MONITOR_ENABLED=false
# Secret the Vercel Cron route checks before running (Vercel sends it).
# CRON_SECRET=your-cron-secret
# Identifying User-Agent with a contact URL — never a spoofed browser string.
# OZB_MONITOR_USER_AGENT=DealStackAU/1.0 (+https://your-site/about; contact: you@example.com)
# Hard cap on feeds touched per run.
# OZB_MONITOR_MAX_FEEDS_PER_RUN=2
# Floor on per-feed polling interval (hours).
# OZB_MONITOR_MIN_INTERVAL_HOURS=12
