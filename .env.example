# DealStack AU — environment variables
# Copy to .env.local (which is gitignored) and fill in real values.
# Never commit real keys. The service-role key is server/script only.

# Public Supabase config (safe to expose to the browser; RLS-limited)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server/script ONLY — bypasses RLS. Do NOT prefix with NEXT_PUBLIC_.
# Used by scripts/seed.ts now, and admin server actions later.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin access is governed solely by the `admins` table in Supabase, checked
# by requireAdmin() (lib/admin/auth.ts), plus a hand-created Supabase Auth user
# for each admin. There is no env-var allowlist — no variable here grants or
# revokes admin access.

# Required in production. Launch-critical: sitemap, robots, canonical URLs, OG
# images and JSON-LD silently fall back to http://localhost:3000 when unset.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional (used in later phases)
# Force the static fallback even if Supabase is configured: static | supabase
# DATA_SOURCE=supabase

# OzBargain feed monitor — OFF by default. Two entry points: the manual dry-run
# script (`npm run monitor:feeds -- --dry-run`) and a secret-gated cron route
# (GET /api/cron/monitor-feeds, scheduled daily via vercel.json). The monitor
# only does anything when OZB_MONITOR_ENABLED=true AND a feed_sources row is
# enabled AND an approved compliance review is on file; see
# docs/ozbargain-monitoring.md.
# OZB_MONITOR_ENABLED=false
# Identifying User-Agent with a contact URL — never a spoofed browser string.
# Required only when the monitor is enabled.
# OZB_MONITOR_USER_AGENT=DealStackAU/1.0 (+https://your-site/about; contact: you@example.com)
# Hard cap on feeds touched per run (default 1).
# OZB_MONITOR_MAX_FEEDS_PER_RUN=10
# Floor on per-feed polling interval, in hours (default 12).
# OZB_MONITOR_MIN_INTERVAL_HOURS=12
# SIGNAL_VALIDATION_DAYS=45
# CARD_DETECT_ENABLED=false
# Offer-change DETECTION — OFF by default; INDEPENDENT of the monitor switch
# above. When "true", a post-run step scans feed items already staged in the
# last 24h (no network) and stages high-signal cashback/gift-card/points rate
# changes into offer_change_candidates (review_state 'new') for the existing
# /admin/offer-changes review flow. Nothing is ever auto-applied. Leave OFF
# until you have reviewed precision EITHER via
# `npm run monitor:feeds -- --dry-run` (flag on locally) OR the "Preview
# detection" panel on /admin/offer-changes (works with the flag off — that is
# its whole purpose) and are happy with what would be staged.
# OZB_OFFER_DETECT_ENABLED=false
# OzBargain EXPIRY RECHECK — OFF by default; a SEPARATE cron from ingestion
# (GET /api/cron/recheck-ozbargain-expiry). When "true", it archives PENDING
# review items on two explicit source signals only: EXPIRY, from structured
# fields OzBargain publishes in its own RSS feeds (<ozb:title-msg type="expired">
# marker / <ozb:meta expiry> passed by >= 24h), captured at ingest and consumed
# with zero extra requests — and DELETION, a confirmed 404/410 from the
# status-only HEAD probe. No HTML is ever fetched or parsed (repository policy:
# RSS/Atom + HEAD only). See docs/ozbargain-expiry-recheck.md. It still needs an
# approved compliance review and OZB_MONITOR_USER_AGENT before any outbound
# request. Leave OFF until validated in production.
# OZB_EXPIRY_RECHECK_ENABLED=false
# PREVIEW MODE — defaults to TRUE (any value other than exactly "false" is
# preview). In preview the job classifies and records metrics but writes NOTHING
# (no feed_items change, no archival, no audit). Run preview first, review the
# "would archive" counts on /admin/monitor, THEN set this to "false" to go live.
# OZB_EXPIRY_RECHECK_DRY_RUN=true
# Items probed per run (clamped to 25–50, default 40).
# OZB_EXPIRY_RECHECK_BATCH_SIZE=40
# Minimum hours between re-probes of the same item (default 20).
# OZB_EXPIRY_RECHECK_MIN_INTERVAL_HOURS=20
# Shared secret for the cron route and read-only monitor health endpoint — both
# check `Authorization: Bearer ${CRON_SECRET}`.
# Vercel Cron sends this automatically when the var is set in the project env. If
# it is unset, the route returns 503 and never runs. Server-only secret — never
# prefix with NEXT_PUBLIC_.
# Vercel Cron runs the route once daily (Hobby plan; keep vercel.json daily). For
# every-3-hour runs, an external scheduler (e.g. cron-job.org) can GET the same
# route with this Bearer token — see docs/ozbargain-monitoring.md.
# CRON_SECRET=generate-a-long-random-string

# Optional ops webhook (e.g. Slack incoming webhook URL) for server-error
# alerts. When set, errors captured by instrumentation.ts onRequestError are
# POSTed here (deduped per error digest, 5-minute window) in addition to the
# structured "[server-error]" lines always written to the function logs.
# Server-only secret — never prefix with NEXT_PUBLIC_.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
